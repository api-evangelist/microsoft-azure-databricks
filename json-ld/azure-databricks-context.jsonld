{
  "@context": {
    "@vocab": "https://schema.org/",
    "databricks": "https://docs.databricks.com/api/azure/workspace/",
    "azure": "https://learn.microsoft.com/azure/databricks/",
    "spark": "https://spark.apache.org/docs/latest/",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "dcterms": "http://purl.org/dc/terms/",

    "Cluster": {
      "@id": "databricks:clusters",
      "@context": {
        "cluster_id": {
          "@id": "dcterms:identifier",
          "@type": "xsd:string"
        },
        "cluster_name": {
          "@id": "schema:name",
          "@type": "xsd:string"
        },
        "spark_version": {
          "@id": "databricks:clusters/spark-version",
          "@type": "xsd:string"
        },
        "node_type_id": {
          "@id": "databricks:clusters/node-type",
          "@type": "xsd:string"
        },
        "driver_node_type_id": {
          "@id": "databricks:clusters/driver-node-type",
          "@type": "xsd:string"
        },
        "num_workers": {
          "@id": "databricks:clusters/num-workers",
          "@type": "xsd:integer"
        },
        "state": {
          "@id": "databricks:clusters/state",
          "@type": "xsd:string"
        },
        "state_message": {
          "@id": "databricks:clusters/state-message",
          "@type": "xsd:string"
        },
        "creator_user_name": {
          "@id": "dcterms:creator",
          "@type": "xsd:string"
        },
        "start_time": {
          "@id": "databricks:clusters/start-time",
          "@type": "xsd:long"
        },
        "terminated_time": {
          "@id": "databricks:clusters/terminated-time",
          "@type": "xsd:long"
        },
        "last_activity_time": {
          "@id": "databricks:clusters/last-activity-time",
          "@type": "xsd:long"
        },
        "autotermination_minutes": {
          "@id": "databricks:clusters/autotermination-minutes",
          "@type": "xsd:integer"
        },
        "cluster_source": {
          "@id": "databricks:clusters/source",
          "@type": "xsd:string"
        },
        "data_security_mode": {
          "@id": "databricks:clusters/data-security-mode",
          "@type": "xsd:string"
        },
        "runtime_engine": {
          "@id": "databricks:clusters/runtime-engine",
          "@type": "xsd:string"
        },
        "single_user_name": {
          "@id": "databricks:clusters/single-user",
          "@type": "xsd:string"
        },
        "instance_pool_id": {
          "@id": "databricks:clusters/instance-pool",
          "@type": "xsd:string"
        },
        "policy_id": {
          "@id": "databricks:clusters/policy",
          "@type": "xsd:string"
        },
        "enable_elastic_disk": {
          "@id": "databricks:clusters/elastic-disk",
          "@type": "xsd:boolean"
        },
        "enable_local_disk_encryption": {
          "@id": "databricks:clusters/local-disk-encryption",
          "@type": "xsd:boolean"
        }
      }
    },

    "AutoScale": {
      "@id": "databricks:clusters/autoscale",
      "@context": {
        "min_workers": {
          "@id": "databricks:clusters/autoscale/min-workers",
          "@type": "xsd:integer"
        },
        "max_workers": {
          "@id": "databricks:clusters/autoscale/max-workers",
          "@type": "xsd:integer"
        }
      }
    },

    "AzureAttributes": {
      "@id": "databricks:clusters/azure-attributes",
      "@context": {
        "first_on_demand": {
          "@id": "databricks:clusters/azure-attributes/first-on-demand",
          "@type": "xsd:integer"
        },
        "availability": {
          "@id": "databricks:clusters/azure-attributes/availability",
          "@type": "xsd:string"
        },
        "spot_bid_max_price": {
          "@id": "databricks:clusters/azure-attributes/spot-bid-max-price",
          "@type": "xsd:double"
        }
      }
    },

    "Job": {
      "@id": "databricks:jobs",
      "@context": {
        "job_id": {
          "@id": "dcterms:identifier",
          "@type": "xsd:long"
        },
        "creator_user_name": {
          "@id": "dcterms:creator",
          "@type": "xsd:string"
        },
        "run_as_user_name": {
          "@id": "databricks:jobs/run-as-user",
          "@type": "xsd:string"
        },
        "created_time": {
          "@id": "dcterms:created",
          "@type": "xsd:long"
        }
      }
    },

    "JobSettings": {
      "@id": "databricks:jobs/settings",
      "@context": {
        "name": {
          "@id": "schema:name",
          "@type": "xsd:string"
        },
        "max_concurrent_runs": {
          "@id": "databricks:jobs/max-concurrent-runs",
          "@type": "xsd:integer"
        },
        "timeout_seconds": {
          "@id": "databricks:jobs/timeout",
          "@type": "xsd:integer"
        },
        "format": {
          "@id": "databricks:jobs/format",
          "@type": "xsd:string"
        }
      }
    },

    "TaskSettings": {
      "@id": "databricks:jobs/task",
      "@context": {
        "task_key": {
          "@id": "dcterms:identifier",
          "@type": "xsd:string"
        },
        "description": {
          "@id": "dcterms:description",
          "@type": "xsd:string"
        },
        "existing_cluster_id": {
          "@id": "databricks:jobs/task/existing-cluster",
          "@type": "xsd:string"
        },
        "job_cluster_key": {
          "@id": "databricks:jobs/task/job-cluster-key",
          "@type": "xsd:string"
        },
        "timeout_seconds": {
          "@id": "databricks:jobs/task/timeout",
          "@type": "xsd:integer"
        },
        "max_retries": {
          "@id": "databricks:jobs/task/max-retries",
          "@type": "xsd:integer"
        },
        "retry_on_timeout": {
          "@id": "databricks:jobs/task/retry-on-timeout",
          "@type": "xsd:boolean"
        },
        "run_if": {
          "@id": "databricks:jobs/task/run-if",
          "@type": "xsd:string"
        }
      }
    },

    "NotebookTask": {
      "@id": "databricks:jobs/task/notebook",
      "@context": {
        "notebook_path": {
          "@id": "databricks:jobs/task/notebook/path",
          "@type": "xsd:string"
        },
        "source": {
          "@id": "databricks:jobs/task/notebook/source",
          "@type": "xsd:string"
        }
      }
    },

    "Run": {
      "@id": "databricks:jobs/runs",
      "@context": {
        "run_id": {
          "@id": "dcterms:identifier",
          "@type": "xsd:long"
        },
        "job_id": {
          "@id": "databricks:jobs/runs/job-id",
          "@type": "xsd:long"
        },
        "run_name": {
          "@id": "schema:name",
          "@type": "xsd:string"
        },
        "creator_user_name": {
          "@id": "dcterms:creator",
          "@type": "xsd:string"
        },
        "number_in_job": {
          "@id": "databricks:jobs/runs/number-in-job",
          "@type": "xsd:long"
        },
        "start_time": {
          "@id": "databricks:jobs/runs/start-time",
          "@type": "xsd:long"
        },
        "end_time": {
          "@id": "databricks:jobs/runs/end-time",
          "@type": "xsd:long"
        },
        "setup_duration": {
          "@id": "databricks:jobs/runs/setup-duration",
          "@type": "xsd:long"
        },
        "execution_duration": {
          "@id": "databricks:jobs/runs/execution-duration",
          "@type": "xsd:long"
        },
        "cleanup_duration": {
          "@id": "databricks:jobs/runs/cleanup-duration",
          "@type": "xsd:long"
        },
        "trigger": {
          "@id": "databricks:jobs/runs/trigger",
          "@type": "xsd:string"
        },
        "run_type": {
          "@id": "databricks:jobs/runs/type",
          "@type": "xsd:string"
        },
        "run_page_url": {
          "@id": "schema:url",
          "@type": "xsd:anyURI"
        },
        "attempt_number": {
          "@id": "databricks:jobs/runs/attempt-number",
          "@type": "xsd:integer"
        }
      }
    },

    "RunState": {
      "@id": "databricks:jobs/runs/state",
      "@context": {
        "life_cycle_state": {
          "@id": "databricks:jobs/runs/state/life-cycle",
          "@type": "xsd:string"
        },
        "result_state": {
          "@id": "databricks:jobs/runs/state/result",
          "@type": "xsd:string"
        },
        "state_message": {
          "@id": "databricks:jobs/runs/state/message",
          "@type": "xsd:string"
        },
        "user_cancelled_or_timedout": {
          "@id": "databricks:jobs/runs/state/user-cancelled",
          "@type": "xsd:boolean"
        }
      }
    },

    "CronSchedule": {
      "@id": "databricks:jobs/schedule",
      "@context": {
        "quartz_cron_expression": {
          "@id": "databricks:jobs/schedule/cron-expression",
          "@type": "xsd:string"
        },
        "timezone_id": {
          "@id": "databricks:jobs/schedule/timezone",
          "@type": "xsd:string"
        },
        "pause_status": {
          "@id": "databricks:jobs/schedule/pause-status",
          "@type": "xsd:string"
        }
      }
    },

    "WorkspaceObject": {
      "@id": "databricks:workspace",
      "@context": {
        "object_type": {
          "@id": "databricks:workspace/object-type",
          "@type": "xsd:string"
        },
        "path": {
          "@id": "databricks:workspace/path",
          "@type": "xsd:string"
        },
        "language": {
          "@id": "databricks:workspace/language",
          "@type": "xsd:string"
        },
        "object_id": {
          "@id": "dcterms:identifier",
          "@type": "xsd:long"
        },
        "created_at": {
          "@id": "dcterms:created",
          "@type": "xsd:long"
        },
        "modified_at": {
          "@id": "dcterms:modified",
          "@type": "xsd:long"
        },
        "resource_id": {
          "@id": "databricks:workspace/resource-id",
          "@type": "xsd:string"
        }
      }
    },

    "Library": {
      "@id": "databricks:clusters/libraries",
      "@context": {
        "jar": {
          "@id": "databricks:clusters/libraries/jar",
          "@type": "xsd:anyURI"
        },
        "whl": {
          "@id": "databricks:clusters/libraries/whl",
          "@type": "xsd:anyURI"
        },
        "requirements": {
          "@id": "databricks:clusters/libraries/requirements",
          "@type": "xsd:string"
        }
      }
    },

    "GitSource": {
      "@id": "databricks:jobs/git-source",
      "@context": {
        "git_url": {
          "@id": "schema:codeRepository",
          "@type": "xsd:anyURI"
        },
        "git_provider": {
          "@id": "databricks:jobs/git-source/provider",
          "@type": "xsd:string"
        },
        "git_branch": {
          "@id": "databricks:jobs/git-source/branch",
          "@type": "xsd:string"
        },
        "git_tag": {
          "@id": "databricks:jobs/git-source/tag",
          "@type": "xsd:string"
        },
        "git_commit": {
          "@id": "databricks:jobs/git-source/commit",
          "@type": "xsd:string"
        }
      }
    },

    "Error": {
      "@id": "databricks:error",
      "@context": {
        "error_code": {
          "@id": "databricks:error/code",
          "@type": "xsd:string"
        },
        "message": {
          "@id": "databricks:error/message",
          "@type": "xsd:string"
        }
      }
    }
  }
}
